{
  "name": "NBA Intel",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },
  "postCreateCommand": "pip install uv && uv sync",
  "forwardPorts": [8080, 9000, 9001, 5000, 8000, 8001],
  "portsAttributes": {
    "8080": {"label": "Airflow"},
    "9000": {"label": "MinIO API"},
    "9001": {"label": "MinIO Console"},
    "5000": {"label": "MLflow"},
    "8000": {"label": "ChromaDB"},
    "8001": {"label": "FastAPI"}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "dbt-labs.dbt-power-user",
        "mtxr.sqltools"
      ]
    }
  }
}
