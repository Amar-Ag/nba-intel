{
  "name": "NBA Intel",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "mounts": [
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
  ],
  "runArgs": [
    "--network=nba-intel_default"
  ],
  "postCreateCommand": "pip install uv && sudo apt-get update && sudo apt-get install -y docker.io docker-compose && curl -sSL install.astronomer.io | sudo bash -s",
  "forwardPorts": [9000, 9001, 5000, 8000, 8001],
  "portsAttributes": {
    "9000": {"label": "MinIO API"},
    "9001": {"label": "MinIO Console"},
    "5000": {"label": "MLflow"},
    "8000": {"label": "ChromaDB"},
    "8001": {"label": "FastAPI"}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "dbt-labs.dbt-power-user",
        "mtxr.sqltools"
      ]
    }
  }
}